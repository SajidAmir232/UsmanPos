# ===== ZAROORI: AWS DEPLOY KE TIME YE BUILD KIYA JAAYE =====
# Ye file AWS ke build system ko batata hai ke Docker image kaise banana hai
# EB single-container mode me build phase me Dockerfile use karta hai

container_commands:
  01_check_dockerfile:
    command: "ls -la POSApp.Web/Dockerfile"
    test: "test -f POSApp.Web/Dockerfile"


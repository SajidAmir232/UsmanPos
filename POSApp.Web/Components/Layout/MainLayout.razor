@inherits LayoutComponentBase
@inject WebAuthService WebAuth
@inject NavigationManager Nav
@inject OfflineSyncService OfflineSync
@implements IDisposable

@if (!WebAuth.IsLoggedIn && !IsPublicPage)
{
    <POSApp.Web.Components.Pages.Login />
}
else if (!WebAuth.IsLoggedIn && IsPublicPage)
{
    @Body
}
else
{
    <div class="page">
        <div class="sidebar">
            <div class="brand">
                POS System
                <small>Web Dashboard</small>
            </div>
            <nav>
                <NavLink href="" Match="NavLinkMatch.All" class="nav-link">
                    <span class="icon">&#9632;</span> <span>Dashboard</span>
                </NavLink>
                <NavLink href="products" class="nav-link">
                    <span class="icon">&#9733;</span> <span>Products</span>
                </NavLink>
                <NavLink href="customers" class="nav-link">
                    <span class="icon">&#9787;</span> <span>Customers</span>
                </NavLink>
                <NavLink href="suppliers" class="nav-link">
                    <span class="icon">&#9881;</span> <span>Suppliers</span>
                </NavLink>
                <NavLink href="pos" class="nav-link">
                    <span class="icon">&#9733;</span> <span>Sales (POS)</span>
                </NavLink>
                <NavLink href="sales" class="nav-link">
                    <span class="icon">&#9733;</span> <span>Sales List</span>
                </NavLink>
                <NavLink href="sales-returns" class="nav-link">
                    <span class="icon">&#8634;</span> <span>Sales Returns</span>
                </NavLink>
                <NavLink href="purchases" class="nav-link">
                    <span class="icon">&#9830;</span> <span>Purchases</span>
                </NavLink>
                <NavLink href="purchase-new" class="nav-link">
                    <span class="icon">&#9830;</span> <span>New Purchase</span>
                </NavLink>
                <NavLink href="customer-payments" class="nav-link">
                    <span class="icon">&#9787;</span> <span>Cust. Payments</span>
                </NavLink>
                <NavLink href="supplier-payments" class="nav-link">
                    <span class="icon">&#9881;</span> <span>Supp. Payments</span>
                </NavLink>
                <NavLink href="customer-ledger" class="nav-link">
                    <span class="icon">&#9787;</span> <span>Customer Ledger</span>
                </NavLink>
                <NavLink href="imei-management" class="nav-link">
                    <span class="icon">&#9742;</span> <span>IMEI Management</span>
                </NavLink>
                <NavLink href="repair-jobs" class="nav-link">
                    <span class="icon">&#9881;</span> <span>Repair Jobs</span>
                </NavLink>
                <NavLink href="reports" class="nav-link">
                    <span class="icon">&#9776;</span> <span>Reports</span>
                </NavLink>
                <NavLink href="settings" class="nav-link">
                    <span class="icon">&#9881;</span> <span>Settings</span>
                </NavLink>
                @if (WebAuth.CurrentUser?.Role == "Admin")
                {
                    <NavLink href="admin" class="nav-link">
                        <span class="icon">&#9733;</span> <span>Admin Panel</span>
                    </NavLink>
                }
            </nav>
        </div>

        <main>
            <div class="topbar">
                <h1>@(PageTitle ?? "POS Dashboard")</h1>
                <div class="user-info" style="display:flex;align-items:center;gap:12px;">
                    <span style="display:inline-flex;align-items:center;gap:6px;font-size:11px;padding:3px 10px;border-radius:20px;background:@(OfflineSync.IsOnline ? "#d1fae5" : "#fee2e2");color:@(OfflineSync.IsOnline ? "#065f46" : "#991b1b");font-weight:600;">
                        <span style="width:6px;height:6px;border-radius:50%;background:@(OfflineSync.IsOnline ? "#10b981" : "#ef4444");display:inline-block;"></span>
                        @(OfflineSync.IsOnline ? "Online" : "Offline")
                    </span>
                    @(WebAuth.CurrentUser?.Username ?? "Admin") | @(WebAuth.CurrentUser?.Role ?? "Admin")
                    <button class="btn btn-ghost btn-sm" style="margin-left:8px;font-size:11px;" @onclick="Logout">Logout</button>
                </div>
            </div>
            <div class="content">
                @Body
            </div>
        </main>
    </div>
}

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">&#10005;</a>
</div>

@code {
    [CascadingParameter]
    private string? PageTitle { get; set; }

    private bool IsPublicPage => Nav.Uri.Contains("/login") || Nav.Uri.Contains("/forgot-password") || Nav.Uri.Contains("/signup");

    protected override void OnInitialized()
    {
        WebAuth.OnAuthStateChanged += StateHasChanged;
        OfflineSync.OnSyncStateChanged += StateHasChanged;
        _ = OfflineSync.InitializeAsync();
    }

    public void Dispose()
    {
        WebAuth.OnAuthStateChanged -= StateHasChanged;
        OfflineSync.OnSyncStateChanged -= StateHasChanged;
    }

    private void Logout()
    {
        WebAuth.Logout();
        Nav.NavigateTo("/", forceLoad: true);
    }
}

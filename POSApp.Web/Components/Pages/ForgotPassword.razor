@page "/forgot-password"
@rendermode InteractiveServer
@inject AuthService AuthService
@inject NavigationManager Nav

<div class="login-page">
    <div class="login-card">
        <h2>Reset Password</h2>
        <div class="subtitle">Enter your registered email to get a temporary password</div>

        @if (!string.IsNullOrEmpty(message))
        {
            <div class="error" style="background:@(success ? "#d1fae5" : "#fee2e2");color:@(success ? "#065f46" : "#991b1b");white-space:pre-line;">@message</div>
        }

        @if (!success)
        {
            <div class="form-group">
                <label>Email Address</label>
                <input class="form-control" @bind="email" @bind:event="oninput" placeholder="Enter your email" @onkeydown="HandleKeyDown" />
            </div>
            <button class="btn btn-primary" @onclick="SubmitReset">Reset Password</button>
        }
        else
        {
            <button class="btn btn-primary" style="margin-top:12px;" @onclick="GoToLogin">Go to Sign In</button>
        }
        <div style="margin-top:16px;text-align:center;">
            <a href="/login" style="font-size:12px;color:#4f46e5;text-decoration:none;">Back to Sign In</a>
        </div>
    </div>
</div>

@code {
    private string email = "";
    private string message = "";
    private bool success;

    private void SubmitReset()
    {
        message = "";
        if (string.IsNullOrWhiteSpace(email))
        {
            message = "Please enter your email address.";
            success = false;
            return;
        }

        var tempPassword = GenerateTempPassword();
        var (ok, msg) = AuthService.AdminResetPasswordByEmail(email, tempPassword);
        success = ok;
        if (ok)
        {
            message = $"Password has been reset!\n\nYour temporary password is:\n{tempPassword}\n\nUse this to login, then change your password in Settings.";
        }
        else
        {
            message = msg;
        }
    }

    private string GenerateTempPassword()
    {
        var random = new Random();
        const string chars = "ABCDEFGHJKLMNPQRSTUVWXYZabcdefghijkmnpqrstuvwxyz23456789";
        return new string(Enumerable.Repeat(chars, 8).Select(s => s[random.Next(s.Length)]).ToArray());
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") SubmitReset();
    }

    private void GoToLogin()
    {
        Nav.NavigateTo("/login");
    }
}

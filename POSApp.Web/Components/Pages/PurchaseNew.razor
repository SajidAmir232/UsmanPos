@page "/purchase-new"
@rendermode InteractiveServer
@inject ProductService ProductService
@inject SupplierService SupplierService
@inject PurchaseInvoiceService PurchaseService

<div class="d-flex align-center justify-between mb-4">
    <h2 style="font-size:16px;font-weight:600;">New Purchase Invoice</h2>
</div>

<div style="display:grid;grid-template-columns:1fr 380px;gap:16px;">
    <div>
        <div class="card mb-3">
            <div class="form-group">
                <label>Supplier</label>
                <select class="form-control form-control-sm" @bind="selectedSupplierGuid">
                    <option value="">-- Select Supplier --</option>
                    @foreach (var s in suppliers)
                    {
                        <option value="@s.Guid">@s.Name</option>
                    }
                </select>
            </div>

            <div class="d-flex gap-2 mb-3">
                <input type="text" class="form-control form-control-sm" placeholder="Search products..." @bind="searchQuery" @bind:event="oninput" style="flex:1;" />
            </div>
            <div class="table-wrap" style="max-height:300px;overflow-y:auto;">
                <table>
                    <thead>
                        <tr><th>Product</th><th>Stock</th><th>Cost Price</th><th>Action</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var p in filteredProducts)
                        {
                            <tr>
                                <td class="fw-600">@p.Name<br/><span class="text-muted text-sm">@p.Sku</span></td>
                                <td>@p.Quantity</td>
                                <td>Rs@(p.PurchasePrice.ToString("N0"))</td>
                                <td><button class="btn btn-primary btn-sm" @onclick="() => AddToCart(p)">Add</button></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div>
        <div class="card" style="position:sticky;top:0;">
            <div class="card-header">Purchase Items</div>

            @if (cartItems.Any())
            {
                <div class="table-wrap mb-3" style="max-height:250px;overflow-y:auto;">
                    <table>
                        <thead><tr><th>Item</th><th>Qty</th><th>Cost</th><th></th></tr></thead>
                        <tbody>
                            @foreach (var item in cartItems)
                            {
                                <tr>
                                    <td style="font-size:12px;">@item.ProductName</td>
                                    <td><input type="number" class="form-control form-control-sm" style="width:50px;" min="1" @bind="item.Quantity" @bind:event="oninput" /></td>
                                    <td><input type="number" class="form-control form-control-sm" style="width:80px;" min="0" @bind="item.CostPrice" @bind:event="oninput" /></td>
                                    <td><button class="btn btn-ghost btn-sm" @onclick="() => RemoveFromCart(item)">&#10005;</button></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div style="text-align:center;padding:20px;color:#94a3b8;font-size:13px;">No items added yet.</div>
            }

            <div style="display:grid;gap:6px;font-size:13px;border-top:1px solid #e2e8f0;padding-top:12px;">
                <div class="d-flex justify-between fw-700" style="font-size:15px;">
                    <span>Total</span>
                    <span style="color:#4f46e5;">Rs@(cartItems.Sum(i => i.CostPrice * i.Quantity).ToString("N0"))</span>
                </div>
            </div>

            <div class="form-group mt-3">
                <label>Paid Amount</label>
                <input type="number" class="form-control form-control-sm" @bind="paidAmount" min="0" />
            </div>

            <button class="btn btn-success mt-2" style="width:100%;justify-content:center;" @onclick="CreatePurchase" disabled="@(!cartItems.Any() || string.IsNullOrEmpty(selectedSupplierGuid))">
                Create Purchase
            </button>

            @if (!string.IsNullOrEmpty(message))
            {
                <div style="margin-top:8px;padding:8px;border-radius:6px;font-size:12px;background:@(isSuccess ? "#d1fae5" : "#fee2e2");color:@(isSuccess ? "#065f46" : "#991b1b");">@message</div>
            }
        </div>
    </div>
</div>

@code {
    private string searchQuery = "";
    private string selectedSupplierGuid = "";
    private List<Product> allProducts = new();
    private List<Supplier> suppliers = new();
    private decimal paidAmount;
    private string message = "";
    private bool isSuccess;
    private List<CartCartItem> cartItems = new();

    private List<Product> filteredProducts => string.IsNullOrWhiteSpace(searchQuery)
        ? allProducts
        : allProducts.Where(p => p.Name.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) || (p.Sku ?? "").Contains(searchQuery, StringComparison.OrdinalIgnoreCase)).ToList();

    protected override void OnInitialized()
    {
        allProducts = ProductService.GetAll();
        suppliers = SupplierService.GetAll();
    }

    private void AddToCart(Product p)
    {
        var existing = cartItems.FirstOrDefault(c => c.ProductGuid == p.Guid);
        if (existing != null) existing.Quantity++;
        else cartItems.Add(new CartCartItem { ProductGuid = p.Guid, ProductName = p.Name, CostPrice = p.PurchasePrice, Quantity = 1 });
    }

    private void RemoveFromCart(CartCartItem item) => cartItems.Remove(item);

    private void CreatePurchase()
    {
        message = "";
        if (!cartItems.Any()) { message = "Add items first."; isSuccess = false; return; }
        if (string.IsNullOrEmpty(selectedSupplierGuid)) { message = "Select a supplier."; isSuccess = false; return; }

        var purchase = new PurchaseInvoice
        {
            SupplierGuid = Guid.Parse(selectedSupplierGuid),
            PurchaseDate = DateTime.Now,
            SubTotal = cartItems.Sum(i => i.CostPrice * i.Quantity),
            PaidAmount = paidAmount,
            Status = paidAmount >= cartItems.Sum(i => i.CostPrice * i.Quantity) ? "Paid" : "Unpaid",
            Items = cartItems.Select(ci => new PurchaseInvoiceItem
            {
                ProductGuid = ci.ProductGuid,
                ProductName = ci.ProductName,
                Quantity = ci.Quantity,
                CostPrice = ci.CostPrice,
                Total = ci.CostPrice * ci.Quantity
            }).ToList()
        };

        PurchaseService.Create(purchase, "web");
        message = $"Purchase created! #{purchase.PurchaseNumber}";
        isSuccess = true;
        cartItems.Clear();
        paidAmount = 0;
        allProducts = ProductService.GetAll();
    }

    private class CartCartItem
    {
        public Guid ProductGuid { get; set; }
        public string ProductName { get; set; } = "";
        public decimal CostPrice { get; set; }
        public decimal Quantity { get; set; }
    }
}

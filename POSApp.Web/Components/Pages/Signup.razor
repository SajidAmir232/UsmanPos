@page "/signup"
@rendermode InteractiveServer
@inject AuthService AuthService
@inject NavigationManager Nav

<div class="login-page">
    <div class="login-card">
        <h2>Create Account</h2>
        <div class="subtitle">Sign up for a new account</div>

        @if (!string.IsNullOrEmpty(error))
        {
            <div class="error">@error</div>
        }
        @if (!string.IsNullOrEmpty(successMsg))
        {
            <div class="error" style="background:#d1fae5;color:#065f46;">@successMsg</div>
        }

        <div class="form-group">
            <label>Username</label>
            <input class="form-control" @bind="username" @bind:event="oninput" placeholder="Choose a username" />
        </div>
        <div class="form-group">
            <label>Email</label>
            <input class="form-control" type="email" @bind="email" @bind:event="oninput" placeholder="Enter your email" />
        </div>
        <div class="form-group">
            <label>Password</label>
            <input class="form-control" type="password" @bind="password" @bind:event="oninput" placeholder="Min 6 characters" />
        </div>
        <div class="form-group">
            <label>Confirm Password</label>
            <input class="form-control" type="password" @bind="confirmPassword" @bind:event="oninput" placeholder="Repeat password" @onkeydown="HandleKeyDown" />
        </div>
        <button class="btn btn-primary" @onclick="DoSignUp">Create Account</button>
        <div style="margin-top:16px;text-align:center;font-size:12px;color:#64748b;">
            Already have an account? <a href="/login" style="color:#4f46e5;text-decoration:none;">Sign In</a>
        </div>
    </div>
</div>

@code {
    private string username = "";
    private string email = "";
    private string password = "";
    private string confirmPassword = "";
    private string error = "";
    private string successMsg = "";

    private void DoSignUp()
    {
        error = "";
        successMsg = "";

        if (string.IsNullOrWhiteSpace(username) || string.IsNullOrWhiteSpace(email) ||
            string.IsNullOrWhiteSpace(password) || string.IsNullOrWhiteSpace(confirmPassword))
        {
            error = "All fields are required.";
            return;
        }

        var (success, message) = AuthService.SignUp(username, email, password, confirmPassword);
        if (success)
        {
            successMsg = message + " Redirecting to login...";
            _ = Task.Delay(2000).ContinueWith(_ => Nav.NavigateTo("/login"));
        }
        else
        {
            error = message;
        }
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") DoSignUp();
    }
}
